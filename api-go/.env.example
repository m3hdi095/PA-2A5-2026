
# Base de données
# En local : DB_HOST=127.0.0.1, DB_PORT=3307
# En Docker / prod : DB_HOST=db, DB_PORT=3306
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=uc_user
DB_PASSWORD=uc_password_2026
DB_NAME=upcycleconnect

# Sécurité JWT, à changer obligatoirement en production
JWT_SECRET=CHANGER_CE_SECRET_EN_PROD_minimum_32_caracteres

# Stripe : mode sandbox en dev, mode live en prod
# Clé de test : sk_test_...   Clé live : sk_live_...
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_ICI
# Webhook secret, récupéré dans le dashboard Stripe > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_ICI

# OneSignal : notifications push
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# SMTP : email transactionnel
# En prod : utiliser le serveur mail de la DMZ ou Mailgun/Brevo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
